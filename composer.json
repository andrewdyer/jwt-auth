{
  "name": "andrewdyer/jwt-auth",
  "description": "A framework-agnostic PHP JWT authentication library for managing tokens, built around contracts for user resolution and claims generation",
  "keywords": ["php", "framework-agnostic", "jwt", "authentication", "tokens", "security"],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Andrew Dyer",
      "homepage": "https://andrewdyer.rocks",
      "role": "Developer"
    }
  ],
  "homepage": "https://github.com/andrewdyer/jwt-auth",
  "support": {
    "issues": "https://github.com/andrewdyer/jwt-auth/issues",
    "source": "https://github.com/andrewdyer/jwt-auth"
  },
  "autoload": {
    "psr-4": {
      "AndrewDyer\\JwtAuth\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "AndrewDyer\\JwtAuth\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.75",
    "phpunit/phpunit": "^10.5"
  },
  "scripts": {
    "cs": "php-cs-fixer fix",
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
